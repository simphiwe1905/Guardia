<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"

    android:layout_width="match_parent"
    android:layout_height="70dp"
    android:layout_margin="10dp"

    android:background="@drawable/rounded_bg">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/expense_detail_box"
        android:layout_width="150dp"
        android:layout_height="70dp"
        android:orientation="vertical"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintTop_toTopOf="parent">

    <TextView
        android:id="@+id/tv_expense_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="30dp"
        android:layout_marginEnd="30dp"



        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintBottom_toTopOf="@id/tv_date_label"

        android:text="Expense A"
        android:textSize="20sp"
        android:textAlignment="textStart"
        android:textColor="@color/pale_pink"
        />

    <TextView
        android:id="@+id/tv_date_label"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="30dp"
        android:layout_marginEnd="30dp"
        app:layout_constraintTop_toBottomOf="@id/tv_expense_name"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"

        android:text="20XX-XX-XX"
        android:textSize="15sp"
        android:textAlignment="textStart"
        android:textColor="@color/pale_pink"
        />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <TextView
        android:id="@+id/expense_price"
        android:layout_width="70dp"
        android:layout_height="40dp"

        android:text="R XXX.XX"
        android:textSize="15sp"
        android:textAlignment="center"
        android:gravity="center"
        android:textColor="@color/pale_pink"

        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toEndOf="@id/expense_detail_box"
        app:layout_constraintEnd_toStartOf="@id/btn_expense_details"

        app:layout_constraintHorizontal_bias="0.5">
    </TextView>

    <ImageButton
        android:id="@+id/btn_expense_details"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:src="@drawable/down_chevron_dark_mode"
        android:background="#410B0B"

        android:scaleX="0.75"
        android:scaleY="0.75"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginEnd="10dp"

        android:contentDescription="More details">
    </ImageButton>


</androidx.constraintlayout.widget.ConstraintLayout>
