        </LinearLayout>

    </ScrollView>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/bottomNav"
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:layout_gravity="bottom"
        android:background="@drawable/bar_background"
        android:layout_marginTop="20sp"
        android:layout_marginBottom="10sp">
        <ImageButton
            android:id="@+id/btn_settings"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:src="@drawable/setting_icon_dark_mode"
            android:background="#410B0B"

            android:onClick="settingsPage"

            android:scaleX="0.75"
            android:scaleY="0.75"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            android:layout_marginStart="20dp"

            android:contentDescription="@string/lbl_settings">
        </ImageButton>
        <ImageButton
            android:id="@+id/btn_home"
            android:layout_width="48sp"
            android:layout_height="48sp"
            android:src="@drawable/home_icon_dark_mode"
            android:background="#410B0B"

            android:onClick="homePage"

            android:scaleX="0.75"
            android:scaleY="0.75"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@id/btn_settings"
            app:layout_constraintEnd_toStartOf="@id/btn_add_expenses"

            android:contentDescription="@string/lbl_home">
        </ImageButton>
        <ImageButton
            android:id="@+id/btn_add_expenses"
            android:layout_width="48sp"
            android:layout_height="48sp"
            android:src="@drawable/add_button_dark_mode"
            android:background="#410B0B"

            android:scaleX="0.75"
            android:scaleY="0.75"

            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.5"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"

            android:contentDescription="@string/lbl_home">
        </ImageButton>
        <ImageButton
            android:id="@+id/btn_goals"
            android:layout_width="48sp"
            android:layout_height="48sp"
            android:src="@drawable/goal_icon_dark_mode"
            android:background="#410B0B"

            android:onClick="goalsPage"

            android:scaleX="0.75"
            android:scaleY="0.75"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@id/btn_add_expenses"
            app:layout_constraintEnd_toStartOf="@id/btn_awards"

            android:contentDescription="@string/lbl_goals">
        </ImageButton>
        <ImageButton
            android:id="@+id/btn_awards"
            android:layout_width="48sp"
            android:layout_height="48sp"
            android:src="@drawable/award_icon_dark_mode"
            android:background="#410B0B"

            android:onClick="awardsPage"


            android:scaleX="0.75"
            android:scaleY="0.75"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            android:layout_marginEnd="20dp"

            android:contentDescription="@string/lbl_awards">
        </ImageButton>
    </androidx.constraintlayout.widget.ConstraintLayout>
</FrameLayout>