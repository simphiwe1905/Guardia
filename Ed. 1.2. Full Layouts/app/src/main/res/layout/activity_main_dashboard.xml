<?xml version="1.0" encoding="utf-8"?>
<!--FrameLayout was the best way to set the design as it was in Figma, so this is non-negotiable-->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black"
    tools:context=".main_dashboard">

    <!--This just sets the background to be the cropped version in the drawables-->
    <ImageView
        android:contentDescription="@string/app_name"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/background"
        />

    <!--The constraint layout here allows for better spacing between the three top bar elements
     and makes them more interchangeable with nested linear layouts if the buttons need labels-->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/top_navigation"
        android:layout_width="match_parent"
        android:layout_height="90dp"
        android:orientation="horizontal">

        <!--Image buttons are the easiest to work with for the buttons we need-->
        <!--The backgrounds are set to black for this theme but will need to be changed between
        themes-->
        <ImageButton
            android:id="@+id/btn_notifications"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/notification_bell_dark_mode"
            android:contentDescription="@string/lbl_notifications"

            android:background="@color/black"

            android:scaleX="0.75"
            android:scaleY="0.75"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            android:layout_marginStart="20dp">

        </ImageButton>

        <!--This nested layout allows the center option, which will be for user settings,
         to have a label directly below the button which will be the user's set profile image-->
        <LinearLayout
            android:id="@id/btn_userOptions"
            android:layout_width="100dp"
            android:layout_height="80dp"
            android:orientation="vertical"
            android:scaleX="0.75"
            android:scaleY="0.75"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.5"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <ImageButton
                android:id="@+id/btn_userOptions"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@color/pale_pink"
                android:contentDescription="@string/lbl_userOptions"

                android:layout_gravity="center">
            </ImageButton>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="@string/placeholder_username"
                android:textSize="20sp"
                android:textAlignment="center"
                android:textColor="@color/pale_pink"/>
        </LinearLayout>

        <ImageButton
            android:id="@+id/btn_darkMode"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:contentDescription="@string/lbl_darkmode"

            android:src="@drawable/dark_mode_switch_dark_mode"

            android:background="@color/black"

            android:scaleX="0.75"
            android:scaleY="0.75"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            android:layout_marginEnd="20dp">
        </ImageButton>


    </androidx.constraintlayout.widget.ConstraintLayout>
    <!--Simple scroll view will just hold the dashboard options,
     and keep them separate from the bottom app bar-->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="90dp">

        <!--The linear layout here will allow each panel to layer vertically in the scroll view-->
        <LinearLayout
            android:id="@+id/dashboardContents"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="250dp"
                android:background="@drawable/rounded_bg"
                android:layout_margin="20sp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/weekly_box"
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:layout_margin="20dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintLeft_toLeftOf="parent"
                    app:layout_constraintTop_toTopOf="parent">

                    <TextView
                        android:id="@+id/tv_weeklyQuestLabel"
                        android:layout_width="match_parent"
                        android:layout_height="20dp"
                        android:layout_marginBottom="50dp"
                        android:gravity="center"
                        android:text="@string/lbl_weeklyQuest"
                        android:textColor="@color/pale_pink"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/tv_weeklyQuest"
                        android:layout_width="match_parent"
                        android:layout_height="20dp"
                        android:layout_marginBottom="20dp"
                        android:gravity="center"
                        android:text="@string/placeholder_weekly_quest"
                        android:textColor="@color/pale_pink"
                        app:layout_constraintTop_toBottomOf="@id/tv_weeklyQuestLabel"/>

                    <com.example.guardia_app.ProgressBar
                        android:id="@+id/pb_weeklyQuestProgress"
                        android:layout_width="match_parent"
                        android:layout_height="20dp"
                        app:layout_constraintTop_toTopOf="@id/tv_weeklyQuest"
                        app:layout_constraintBottom_toTopOf="@id/tv_timeRemainingLabel"
                        />


                    <TextView
                        android:id="@+id/tv_timeRemainingLabel"
                        android:layout_width="match_parent"
                        android:layout_height="20dp"
                        android:gravity="center"
                        android:text="@string/placeholder_time_remaining"
                        android:textColor="@color/pale_pink"
                        app:layout_constraintBottom_toBottomOf="parent" />

                </androidx.constraintlayout.widget.ConstraintLayout>

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/daily_box"
                    android:layout_width="150dp"
                    android:layout_height="200dp"
                    app:layout_constraintLeft_toRightOf="@id/weekly_box"
                    app:layout_constraintRight_toRightOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"

                    android:layout_marginBottom="20dp"
                    android:layout_marginTop="48dp">

                    <LinearLayout
                        android:id="@+id/dailyQuestA"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:orientation="horizontal"
                        app:layout_constraintTop_toTopOf="parent">

                        <TextView
                            android:id="@+id/tv_lbl_dailyQuestA"
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:textColor="@color/pale_pink"
                            android:text="@string/placeholder_quest_name"
                            android:textAlignment="center">
                        </TextView>

                        <com.example.guardia_app.ProgressBar
                            android:id="@+id/pb_dailyQuestProgressA"
                            android:layout_width="match_parent"
                            android:layout_height="20dp"
                            app:layout_constraintTop_toTopOf="@id/tv_weeklyQuest"
                            app:layout_constraintBottom_toTopOf="@id/tv_timeRemainingLabel"
                            android:layout_gravity="center"

                            />

                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/dailyQuestB"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:orientation="horizontal"
                        app:layout_constraintTop_toBottomOf="@id/dailyQuestA"
                        app:layout_constraintBottom_toTopOf="@id/dailyQuestC">

                        <TextView
                            android:id="@+id/tv_lbl_dailyQuestB"
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:textColor="@color/pale_pink"
                            android:text="@string/placeholder_quest_name"
                            android:textAlignment="center">
                        </TextView>

                        <com.example.guardia_app.ProgressBar
                            android:id="@+id/pb_dailyQuestProgressB"
                            android:layout_width="match_parent"
                            android:layout_height="20dp"
                            app:layout_constraintTop_toTopOf="@id/tv_weeklyQuest"
                            app:layout_constraintBottom_toTopOf="@id/tv_timeRemainingLabel"
                            android:layout_gravity="center"
                            />

                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/dailyQuestC"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:orientation="horizontal"
                        app:layout_constraintTop_toBottomOf="@id/dailyQuestB"
                        app:layout_constraintBottom_toBottomOf="parent">

                        <TextView
                            android:id="@+id/tv_lbl_dailyQuestC"
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:textColor="@color/pale_pink"
                            android:text="@string/placeholder_quest_name"
                            android:textAlignment="center">
                        </TextView>

                        <com.example.guardia_app.ProgressBar
                            android:id="@+id/pb_dailyQuestProgressC"
                            android:layout_width="match_parent"
                            android:layout_height="20dp"
                            app:layout_constraintTop_toTopOf="@id/tv_weeklyQuest"
                            app:layout_constraintBottom_toTopOf="@id/tv_timeRemainingLabel"
                            android:layout_gravity="center"
                            />

                    </LinearLayout>

                </androidx.constraintlayout.widget.ConstraintLayout>

                <ImageButton
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="@color/strong_maroon"
                    android:src="@drawable/more_details_icon_dark_mode"
                    app:layout_constraintRight_toRightOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    android:contentDescription="@string/lbl_goals"

                    android:scaleY="0.75"
                    android:scaleX="0.75"/>

            </androidx.constraintlayout.widget.ConstraintLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="300dp"
                android:background="@drawable/rounded_bg"
                android:layout_margin="20sp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/weekly_expenses"
                    android:layout_width="150dp"
                    android:layout_height="200dp"
                    app:layout_constraintLeft_toLeftOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    android:layout_margin="20dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:text="This Weeks Expenses"
                        android:textColor="@color/pale_pink"
                        android:textAlignment="center"

                        android:textSize="20dp"
                        app:layout_constraintTop_toTopOf="parent"
                        />

                    <com.github.mikephil.charting.charts.BarChart
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"

                        />
                </androidx.constraintlayout.widget.ConstraintLayout>

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/status_box"
                    android:layout_width="150dp"
                    android:layout_height="150dp"
                    app:layout_constraintLeft_toRightOf="@id/weekly_expenses"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    android:layout_margin="20dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintLeft_toLeftOf="parent"

                        android:textAlignment="center"
                        android:textColor="@color/pale_pink"
                        android:textSize="20dp"
                        android:text="Status:"
                        >

                    </TextView>
                </androidx.constraintlayout.widget.ConstraintLayout>

                <ImageButton
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="@color/strong_maroon"
                    android:src="@drawable/more_details_icon_dark_mode"
                    app:layout_constraintRight_toRightOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    android:contentDescription="@string/lbl_goals"

                    android:scaleY="0.75"
                    android:scaleX="0.75"/>

            </androidx.constraintlayout.widget.ConstraintLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="500dp"
                android:background="@drawable/rounded_bg"
                android:layout_margin="20sp">

                <TextView
                    android:id="@+id/tv_lbl_categoryBreakdown"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"

                    android:textColor="@color/pale_pink"
                    android:text="This Weeks Expenses"
                    android:textAlignment="center"
                    android:padding="10dp"
                    android:textSize="20dp"

                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toTopOf="@id/categoryBreakdownChart"/>

                <com.github.mikephil.charting.charts.PieChart
                    android:id="@+id/categoryBreakdownChart"
                    android:layout_width="300dp"
                    android:layout_height="300dp"
                    android:layout_marginTop="20dp"

                    app:layout_constraintTop_toTopOf="@id/tv_lbl_categoryBreakdown"
                    app:layout_constraintLeft_toLeftOf="parent"
                    app:layout_constraintRight_toRightOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"/>

            </androidx.constraintlayout.widget.ConstraintLayout>
        </LinearLayout>
    </ScrollView>

    <!--This on works the same as the top navigation-->
    <!--All the elements are drawables, converted from svg's
    into android vector assets and resized from 24x24px to 48x48dp
    and scaled with scaleX and scaleY to keep the size consistent and clear-->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/bottomNav"
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:layout_gravity="bottom"
        android:background="@drawable/bar_background"
        android:layout_marginTop="20sp"
        android:layout_marginBottom="10sp">

        <ImageButton
            android:id="@+id/btn_settings"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:src="@drawable/setting_icon_dark_mode"
            android:background="@color/strong_maroon"

            android:scaleX="0.75"
            android:scaleY="0.75"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            android:layout_marginStart="20dp"

            android:onClick="settingsPage"

            android:contentDescription="@string/lbl_settings">
        </ImageButton>
        <ImageButton
            android:id="@+id/btn_expenses"
            android:layout_width="48sp"
            android:layout_height="48sp"
            android:src="@drawable/expenses_button_dark_mode"
            android:background="@color/strong_maroon"

            android:scaleX="0.75"
            android:scaleY="0.75"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@id/btn_settings"
            app:layout_constraintEnd_toStartOf="@id/btn_categories"

            android:onClick="expensePage"

            android:contentDescription="@string/lbl_expenses">
        </ImageButton>
        <ImageButton
            android:id="@+id/btn_categories"
            android:layout_width="48sp"
            android:layout_height="48sp"
            android:src="@drawable/options_icon_dark_mode"
            android:background="@color/strong_maroon"

            android:scaleX="0.75"
            android:scaleY="0.75"

            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.5"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"

            android:onClick="categoriesPage"

            android:contentDescription="@string/lbl_categories">
        </ImageButton>
        <ImageButton
            android:id="@+id/btn_goals"
            android:layout_width="48sp"
            android:layout_height="48sp"
            android:src="@drawable/goal_icon_dark_mode"
            android:background="@color/strong_maroon"


            android:scaleX="0.75"
            android:scaleY="0.75"

            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"

            app:layout_constraintStart_toEndOf="@id/btn_categories"
            app:layout_constraintEnd_toStartOf="@id/btn_awards"

            android:onClick="goalsPage"

            android:contentDescription="@string/lbl_goals">
        </ImageButton>
        <ImageButton
            android:id="@+id/btn_awards"
            android:layout_width="48sp"
            android:layout_height="48sp"
            android:src="@drawable/award_icon_dark_mode"
            android:background="@color/strong_maroon"


            android:scaleX="0.75"
            android:scaleY="0.75"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            android:layout_marginEnd="20dp"

            android:onClick="awardsPage"

            android:contentDescription="@string/lbl_awards">
        </ImageButton>
    </androidx.constraintlayout.widget.ConstraintLayout>

</FrameLayout>