<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Guardia_App">
        <activity
            android:name=".settings_dashboard"
            android:exported="false" />
        <activity
            android:name=".categories_dashboard"
            android:exported="false" />
        <activity
            android:name=".goals_dashboard"
            android:exported="false"
            android:label="@string/title_activity_goals_dashboard"
            android:theme="@style/Theme.Guardia_App" />
        <activity
            android:name=".awards_dashboard"
            android:exported="false" />
        <activity
            android:name=".expenses_dashboard"
            android:exported="false" />
        <activity
            android:name=".main_dashboard"
            android:exported="true"
            android:windowFullscreen="true"
            android:windowTranslucentStatus="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>