<?xml version="1.0" encoding="utf-8"?>
<!--
    Login Page Layout
    This screen allows users to log into the Guardia app or navigate to the account creation screen.
    It uses a vertical LinearLayout to stack elements from top to bottom.
-->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".login_page">

    <!-- Background Image -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/guardia"
        android:scaleType="centerCrop" />

    <!-- Optional Dark Overlay (for better visibility) -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#80000000"/>

<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    tools:context=".login_page">

    <!--
        Top Navigation Bar
        Contains quick-access icons like notifications and theme settings.
    -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="35dp"
        android:orientation="horizontal">

        <!-- Bell Icon: Typically used for notifications or opening a menu -->
        <ImageButton
            android:id="@+id/btnMenu"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@android:color/transparent"
            android:contentDescription="notification button"
            android:padding="8dp"
            android:src="@drawable/phiwe_bell"
            app:tint="@android:color/white" />

        <!-- Spacer: This empty view with layout_weight="1" pushes the icons to the far edges -->
        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <!-- Night/Theme Icon: Used to toggle between light and dark modes -->
        <ImageButton
            android:id="@+id/btnSettings"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@android:color/transparent"
            android:contentDescription="themes button"
            android:padding="8dp"
            android:src="@drawable/moon"
            app:tint="@android:color/white" />
    </LinearLayout>

    <!--
        Main Login Form
        Contains the profile image, input fields, and action buttons.
        This section is centered on the screen using android:gravity="center".
    -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingLeft="24dp"
        android:paddingRight="24dp">

        <!-- Profile Image: A visual placeholder for the user's avatar -->
        <ImageView
            android:id="@+id/imgProfile"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:layout_marginBottom="30dp"
            android:background="@drawable/bg_circle"
            android:padding="24dp"
            android:src="@drawable/phiwe_person"
            app:tint="#2E2E2E" />

        <!-- Username Input Field: Where users type their unique account name -->
        <EditText
            android:id="@+id/etUsername"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginBottom="14dp"
            android:background="@drawable/bg_edittext"
            android:hint="Enter Username "
            android:inputType="text"
            android:paddingLeft="16dp"
            android:paddingRight="16dp"
            android:textColor="@android:color/white"
            android:textColorHint="#D9B2B2" />

        <!-- Password Input Field: Masked input for privacy (inputType="textPassword") -->
        <EditText
            android:id="@+id/etPassword"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginBottom="20dp"
            android:background="@drawable/bg_edittext"
            android:hint="Enter Password"
            android:inputType="textPassword"
            android:paddingLeft="16dp"
            android:paddingRight="16dp"
            android:textColor="@android:color/white"
            android:textColorHint="#D9B2B2" />

        <!-- Login Button: Initiates the authentication process -->
        <Button
            android:id="@+id/btnLogin"
            android:layout_width="140dp"
            android:layout_height="45dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_button"
            android:text="Login"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            android:textSize="14sp" />

        <!-- New Account Button: Navigates to the Registration screen -->
        <Button
            android:id="@+id/btnCreateAccount"
            android:layout_width="140dp"
            android:layout_height="45dp"
            android:background="@drawable/bg_button"
            android:text="New Account"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            android:textSize="14sp" />

    </LinearLayout>

</LinearLayout>
</FrameLayout>
