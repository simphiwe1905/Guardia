<?xml version="1.0" encoding="utf-8"?>

<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".login_page">

    <!-- Background Image -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/guardia"
        android:scaleType="centerCrop" />

    <!-- Optional Dark Overlay (for better visibility) -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#80000000"/>

<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/expense_pageMain"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:fitsSystemWindows="true"
    tools:context=".expense_page">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingTop="24dp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingBottom="12dp">

            <!-- Top Bar inside scroll -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <ImageButton
                    android:id="@+id/btnExpenseMenu"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@android:color/transparent"
                    android:contentDescription="notification button"
                    android:padding="6dp"
                    android:src="@drawable/phiwe_bell"
                    app:tint="@android:color/white" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1" />

                <ImageButton
                    android:id="@+id/btnExpenseSettings"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@android:color/transparent"
                    android:contentDescription="themes button"
                    android:padding="6dp"
                    android:src="@drawable/moon"
                    app:tint="@android:color/white" />
            </LinearLayout>

            <!-- Icon -->
            <ImageView
                android:id="@+id/imgExpenseIcon"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_marginBottom="12dp"
                android:background="@drawable/bg_circle"
                android:padding="16dp"
                android:src="@drawable/phiwe_person"
                app:tint="#2E2E2E" />

            <!-- Title -->
            <TextView
                android:id="@+id/tvAddExpenseTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:text="Add Expense"
                android:textColor="@android:color/white"
                android:textSize="18sp"
                android:textStyle="bold" />

            <!-- Expense Name -->
            <EditText
                android:id="@+id/etExpenseName"
                android:layout_width="match_parent"
                android:layout_height="45dp"
                android:layout_marginBottom="8dp"
                android:background="@drawable/bg_edittext"
                android:hint="Enter Expense Name"
                android:inputType="textCapWords"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:textColor="@android:color/white"
                android:textColorHint="#D9B2B2"
                android:textSize="13sp" />

            <!-- Amount -->
            <EditText
                android:id="@+id/etExpenseAmount"
                android:layout_width="match_parent"
                android:layout_height="45dp"
                android:layout_marginBottom="8dp"
                android:background="@drawable/bg_edittext"
                android:hint="Enter Amount"
                android:inputType="numberDecimal"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:textColor="@android:color/white"
                android:textColorHint="#D9B2B2"
                android:textSize="13sp" />

            <!-- Category -->
            <EditText
                android:id="@+id/etExpenseCategory"
                android:layout_width="match_parent"
                android:layout_height="45dp"
                android:layout_marginBottom="8dp"
                android:background="@drawable/bg_edittext"
                android:hint="Enter Category"
                android:inputType="textCapWords"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:textColor="@android:color/white"
                android:textColorHint="#D9B2B2"
                android:textSize="13sp" />

            <!-- Date -->
            <EditText
                android:id="@+id/etExpenseDate"
                android:layout_width="match_parent"
                android:layout_height="45dp"
                android:layout_marginBottom="8dp"
                android:background="@drawable/bg_edittext"
                android:hint="Enter Date (tap to select)"
                android:focusable="false"
                android:clickable="true"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:textColor="@android:color/white"
                android:textColorHint="#D9B2B2"
                android:textSize="13sp" />

            <!-- Description -->
            <EditText
                android:id="@+id/etExpenseDescription"
                android:layout_width="match_parent"
                android:layout_height="70dp"
                android:layout_marginBottom="12dp"
                android:background="@drawable/bg_edittext"
                android:gravity="top|start"
                android:hint="Enter Description"
                android:inputType="textMultiLine"
                android:paddingStart="14dp"
                android:paddingTop="10dp"
                android:paddingEnd="14dp"
                android:textColor="@android:color/white"
                android:textColorHint="#D9B2B2"
                android:textSize="13sp" />

            <!-- Photo Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="12dp">

                <ImageView
                    android:id="@+id/imgExpensePhoto"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@android:drawable/ic_menu_camera"
                    android:scaleType="centerCrop"
                    android:background="@drawable/bg_edittext"
                    android:layout_marginEnd="12dp" />

                <Button
                    android:id="@+id/btnCapturePhoto"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_button"
                    android:text="Add Photo"
                    android:textAllCaps="false"
                    android:textColor="@android:color/white"
                    android:textSize="13sp"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp" />
            </LinearLayout>

            <!-- Save Button -->
            <Button
                android:id="@+id/btnSaveExpense"
                android:layout_width="150dp"
                android:layout_height="40dp"
                android:layout_marginBottom="6dp"
                android:background="@drawable/bg_button"
                android:text="Save Expense"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:textSize="13sp" />

            <!-- Back Button -->
            <Button
                android:id="@+id/btnBackToDashboard"
                android:layout_width="150dp"
                android:layout_height="50dp"
                android:background="@drawable/bg_button"
                android:text="Back to Dashboard"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:textSize="13sp" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>
</FrameLayout>