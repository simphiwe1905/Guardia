<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/expense_pageMain"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#0A0A0A"
    tools:context=".expense_page">

    <!-- Top bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="35dp"
        android:orientation="horizontal">

        <!-- Bell icon on the left -->
        <ImageButton
            android:id="@+id/btnExpenseMnu"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@android:color/white"
            android:contentDescription="Menu button"
            android:padding="8dp"
            android:src="@drawable/phiwe_bell" />

        <LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
            xmlns:tools="http://schemas.android.com/tools"
            android:id="@+id/addExpenseMain"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="16dp"
            android:background="#0A0A0A"
            tools:context=".AddExpenseActivity">

            <!-- Top bar -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="35dp"
                android:orientation="horizontal">

                <!-- Bell icon on the left -->
                <ImageButton
                    android:id="@+id/btnExpenseMenu"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@android:color/white"
                    android:contentDescription="Menu button"
                    android:padding="8dp"
                    android:src="@drawable/phiwe_bell" />

                <!-- Spacer -->
                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1" />

                <!-- Moon icon on the right -->
                <ImageButton
                    android:id="@+id/btnExpenseSetting"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@android:color/white"
                    android:contentDescription="Settings button"
                    android:padding="8dp"
                    android:src="@drawable/moon" />

            </LinearLayout>

            <!-- Main content area -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:paddingLeft="24dp"
                android:paddingRight="24dp"
                android:paddingTop="20dp">

                <!-- Page icon -->
                <ImageView
                    android:id="@+id/imgExpenseIcons"
                    android:layout_width="110dp"
                    android:layout_height="110dp"
                    android:layout_marginBottom="20dp"
                    android:background="@drawable/bg_circle"
                    android:padding="22dp"
                    android:src="@drawable/phiwe_person"
                    app:tint="#2E2E2E" />

                <!-- Title -->
                <TextView
                    android:id="@+id/tvExpensesTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp"
                    android:text="Add Expense"
                    android:textColor="@android:color/white"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <!-- Expense name input -->
                <EditText
                    android:id="@+id/etExpenseNames"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/bg_edittext"
                    android:hint="Enter Expense Name"
                    android:inputType="textCapWords"
                    android:paddingLeft="16dp"
                    android:paddingRight="16dp"
                    android:textColor="@android:color/white"
                    android:textColorHint="#D9B2B2" />

                <!-- Expense amount input -->
                <EditText
                    android:id="@+id/etExpenseAmounts"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/bg_edittext"
                    android:hint="Enter Amount"
                    android:inputType="numberDecimal"
                    android:paddingLeft="16dp"
                    android:paddingRight="16dp"
                    android:textColor="@android:color/white"
                    android:textColorHint="#D9B2B2" />

                <!-- Expense category input -->
                <EditText
                    android:id="@+id/etExpenseCategories"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/bg_edittext"
                    android:hint="Enter Category"
                    android:inputType="textCapWords"
                    android:paddingLeft="16dp"
                    android:paddingRight="16dp"
                    android:textColor="@android:color/white"
                    android:textColorHint="#D9B2B2" />

                <!-- Expense date input -->
                <EditText
                    android:id="@+id/etExpenseDates"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/bg_edittext"
                    android:hint="Enter Date"
                    android:inputType="date"
                    android:paddingLeft="16dp"
                    android:paddingRight="16dp"
                    android:textColor="@android:color/white"
                    android:textColorHint="#D9B2B2" />

                <!-- Expense description input -->
                <EditText
                    android:id="@+id/etExpenseDescriptions"
                    android:layout_width="match_parent"
                    android:layout_height="90dp"
                    android:layout_marginBottom="20dp"
                    android:background="@drawable/bg_edittext"
                    android:gravity="top"
                    android:hint="Enter Description"
                    android:inputType="textMultiLine"
                    android:paddingLeft="16dp"
                    android:paddingTop="12dp"
                    android:paddingRight="16dp"
                    android:textColor="@android:color/white"
                    android:textColorHint="#D9B2B2" />

                <!-- Save expense button -->
                <Button
                    android:id="@+id/btnSaveExpenses"
                    android:layout_width="160dp"
                    android:layout_height="45dp"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/bg_button"
                    android:text="Save Expense"
                    android:textAllCaps="false"
                    android:textColor="@android:color/white"
                    android:textSize="14sp" />

                <!-- Back button -->
                <Button
                    android:id="@+id/btnReturnToDashboard"
                    android:layout_width="160dp"
                    android:layout_height="45dp"
                    android:background="@color/black"
                    android:text="Back to Dashboard"
                    android:textAllCaps="false"
                    android:textColor="@android:color/white"
                    android:textSize="14sp" />

            </LinearLayout>

        </LinearLayout>

        <!-- Spacer -->
        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <!-- Moon icon on the right -->
        <ImageButton
            android:id="@+id/btnExpenseSettings"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@android:color/transparent"
            android:contentDescription="Settings button"
            android:padding="8dp"
            android:src="@drawable/moon"
            />
    </LinearLayout>

    <!-- Main content area -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingLeft="24dp"
        android:paddingRight="24dp"
        android:paddingTop="20dp">

        <!-- Page icon -->
        <ImageView
            android:id="@+id/imgExpenseIcon"
            android:layout_width="110dp"
            android:layout_height="110dp"
            android:layout_marginBottom="20dp"
            android:background="@drawable/bg_circle"
            android:padding="22dp"
            android:src="@drawable/phiwe_person"
             />

        <!-- Title -->
        <TextView
            android:id="@+id/tvAddExpenseTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            android:text="Add Expense"
            android:textColor="@android:color/white"
            android:textSize="24sp"
            android:textStyle="bold" />

        <!-- Expense name input -->
        <EditText
            android:id="@+id/etExpenseName"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_edittext"
            android:hint="Enter Expense Name"
            android:inputType="textCapWords"
            android:paddingLeft="16dp"
            android:paddingRight="16dp"
            android:textColor="@android:color/white"
            android:textColorHint="#D9B2B2" />

        <!-- Expense amount input -->
        <EditText
            android:id="@+id/etExpenseAmount"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_edittext"
            android:hint="Enter Amount"
            android:inputType="numberDecimal"
            android:paddingLeft="16dp"
            android:paddingRight="16dp"
            android:textColor="@android:color/white"
            android:textColorHint="#D9B2B2" />

        <!-- Expense category input -->
        <EditText
            android:id="@+id/etExpenseCategory"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_edittext"
            android:hint="Enter Category"
            android:inputType="textCapWords"
            android:paddingLeft="16dp"
            android:paddingRight="16dp"
            android:textColor="@android:color/white"
            android:textColorHint="#D9B2B2" />

        <!-- Expense date input -->
        <EditText
            android:id="@+id/etExpenseDate"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_edittext"
            android:hint="Enter Date"
            android:inputType="date"
            android:paddingLeft="16dp"
            android:paddingRight="16dp"
            android:textColor="@android:color/white"
            android:textColorHint="#D9B2B2" />

        <!-- Expense description input -->
        <EditText
            android:id="@+id/etExpenseDescription"
            android:layout_width="match_parent"
            android:layout_height="90dp"
            android:layout_marginBottom="20dp"
            android:background="@drawable/bg_edittext"
            android:gravity="top"
            android:hint="Enter Description"
            android:inputType="textMultiLine"
            android:paddingLeft="16dp"
            android:paddingTop="12dp"
            android:paddingRight="16dp"
            android:textColor="@android:color/white"
            android:textColorHint="#D9B2B2" />

        <!-- Save expense button -->
        <Button
            android:id="@+id/btnSaveExpense"
            android:layout_width="160dp"
            android:layout_height="45dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_button"
            android:text="Save Expense"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            android:textSize="14sp" />

        <!-- Back button -->
        <Button
            android:id="@+id/btnBackToDashboard"
            android:layout_width="160dp"
            android:layout_height="45dp"
            android:background="@drawable/bg_button"
            android:text="Back to Dashboard"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            android:textSize="14sp" />

    </LinearLayout>

</LinearLayout>