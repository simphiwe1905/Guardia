<?xml version="1.0" encoding="utf-8"?>

<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/dashboardMain"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@drawable/guardia"
    tools:context=".dashboard">

    <!-- Top bar section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="35dp"
        android:orientation="horizontal">

        <!-- Left icon -->
        <ImageButton
            android:id="@+id/btnDashboardMenu"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@android:color/transparent"
            android:contentDescription="Menu button"
            android:padding="8dp"
            android:src="@drawable/phiwe_bell"
            app:tint="@android:color/white" />

        <!-- Spacer to push the next icon to the right -->
        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <!-- Right icon -->
        <ImageButton
            android:id="@+id/btnDashboardSettings"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@android:color/transparent"
            android:contentDescription="Settings button"
            android:padding="8dp"
            android:src="@drawable/moon"
            app:tint="@android:color/white" />
    </LinearLayout>

    <!-- Main dashboard content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingTop="20dp">

        <!-- Profile / welcome section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="24dp">

            <!-- User icon -->
            <ImageView
                android:id="@+id/imgDashboardProfile"
                android:layout_width="70dp"
                android:layout_height="70dp"
                android:background="@drawable/bg_circle"
                android:padding="14dp"
                android:src="@drawable/phiwe_person"
                app:tint="#2E2E2E" />

            <!-- Space between image and text -->
            <View
                android:layout_width="16dp"
                android:layout_height="1dp" />

            <!-- Welcome text section -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvWelcome"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Welcome Back"
                    android:textColor="@android:color/white"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvUsernameDisplay"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="User's Name"
                    android:textColor="#D9B2B2"
                    android:textSize="16sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Summary title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Overview"
            android:textColor="@android:color/white"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="14dp" />

        <!-- First summary card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="90dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_edittext"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/tvTotalBalanceLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Total Balance"
                android:textColor="#F3DADA"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvTotalBalanceValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="R 0,00"
                android:textColor="@android:color/white"
                android:textSize="24sp"
                android:textStyle="bold"
                android:layout_marginTop="8dp" />
        </LinearLayout>

        <!-- Second summary card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="90dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_edittext"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/tvExpensesLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Expenses This Month"
                android:textColor="#F3DADA"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvExpensesValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="R 0,00"
                android:textColor="@android:color/white"
                android:textSize="24sp"
                android:textStyle="bold"
                android:layout_marginTop="8dp" />
        </LinearLayout>

        <!-- Third summary card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="90dp"
            android:layout_marginBottom="20dp"
            android:background="@drawable/bg_edittext"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/tvSavingsLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Savings Goal"
                android:textColor="#F3DADA"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvSavingsValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="R 0,000 / R 0,000"
                android:textColor="@android:color/white"
                android:textSize="24sp"
                android:textStyle="bold"
                android:layout_marginTop="8dp" />
        </LinearLayout>

        <!-- Action buttons title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Quick Actions"
            android:textColor="@android:color/white"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="14dp" />

        <!-- First row of buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <Button
                android:id="@+id/btnAddExpense"
                android:layout_width="0dp"
                android:layout_height="45dp"
                android:layout_weight="1"
                android:layout_marginRight="8dp"
                android:background="@drawable/bg_button"
                android:text="Add Expense"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:textSize="13sp" />

            <Button
                android:id="@+id/btnViewExpenses"
                android:layout_width="0dp"
                android:layout_height="45dp"
                android:layout_weight="1"
                android:layout_marginLeft="8dp"
                android:background="@drawable/bg_button"
                android:text="View Expenses"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- Second row of buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <Button
                android:id="@+id/btnGoals"
                android:layout_width="0dp"
                android:layout_height="45dp"
                android:layout_weight="1"
                android:layout_marginRight="8dp"
                android:background="@drawable/bg_button"
                android:text="Goals"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:textSize="13sp" />

            <Button
                android:id="@+id/btnAnalysis"
                android:layout_width="0dp"
                android:layout_height="45dp"
                android:layout_weight="1"
                android:layout_marginLeft="8dp"
                android:background="@drawable/bg_button"
                android:text="Analysis"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- Third row of buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnAchievements"
                android:layout_width="0dp"
                android:layout_height="45dp"
                android:layout_weight="1"
                android:layout_marginRight="8dp"
                android:background="@drawable/bg_button"
                android:text="Achievements"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:textSize="13sp" />

            <Button
                android:id="@+id/btnLogout"
                android:layout_width="0dp"
                android:layout_height="45dp"
                android:layout_weight="1"
                android:layout_marginLeft="8dp"
                android:background="@drawable/bg_button"
                android:text="Logout"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:textSize="13sp" />
        </LinearLayout>

    </LinearLayout>

</LinearLayout>