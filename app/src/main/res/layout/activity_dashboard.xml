<?xml version="1.0" encoding="utf-8"?>
<!--
    Dashboard Activity Layout
    This is the main "Home" screen of the Guardia app.
    It uses a vertical LinearLayout to stack the top bar, profile section,
    financial summary, and quick actions from top to bottom.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/dashboardMain"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@drawable/guardia"
    tools:context=".dashboard">

    <!--
        Top Bar Section
        A horizontal bar that holds the notification bell and theme toggle icons.
    -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="35dp"
        android:orientation="horizontal">

        <!-- Left Icon: Used for notifications (phiwe_bell) -->
        <ImageButton
            android:id="@+id/btnDashboardMenu"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@android:color/transparent"
            android:contentDescription="notification button"
            android:padding="8dp"
            android:src="@drawable/phiwe_bell"
            app:tint="@android:color/white" />

        <!--
            Spacer View
            The 'layout_weight="1"' tells this view to take up all available space in the middle.
            This pushes the bell to the far left and the moon to the far right.
        -->
        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <!-- Right Icon: Used for theme/settings (moon) -->
        <ImageButton
            android:id="@+id/btnDashboardSettings"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@android:color/transparent"
            android:contentDescription="themes button"
            android:padding="8dp"
            android:src="@drawable/moon"
            app:tint="@android:color/white" />
    </LinearLayout>

    <!--
        Main Dashboard Content
        The 'layout_weight="1"' here ensures this section fills the rest of the screen height.
    -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingTop="20dp">

        <!--
            Profile / Welcome Section
            Displays the user's avatar and a personal greeting.
        -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="24dp">

            <!-- Profile Picture placeholder -->
            <ImageView
                android:id="@+id/imgDashboardProfile"
                android:layout_width="70dp"
                android:layout_height="70dp"
                android:background="@drawable/bg_circle"
                android:padding="14dp"
                android:src="@drawable/phiwe_person"
                app:tint="#2E2E2E" />

            <!-- Margin View: Creates a 16dp gap between the image and the text -->
            <View
                android:layout_width="16dp"
                android:layout_height="1dp" />

            <!-- Welcome message and dynamic username display -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvWelcome"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Welcome Back"
                    android:textColor="@android:color/white"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvUsernameDisplay"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="User's Name"
                    android:textColor="#D9B2B2"
                    android:textSize="16sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Section Title for the financial summary -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Overview"
            android:textColor="@android:color/white"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="14dp" />

        <!--
            Summary Cards
            These cards show key financial data. Each uses a vertical LinearLayout
            with a specific background drawable to look like a card.
        -->

        <!-- Card 1: Total Balance -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_edittext"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/tvTotalBalanceLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Total Balance"
                android:textColor="#F3DADA"
                android:textSize="20dp" />

            <TextView
                android:id="@+id/tvTotalBalanceValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="R 0,00"
                android:textColor="@android:color/white"
                android:textSize="24sp"
                android:textStyle="bold"
                android:layout_marginTop="8dp" />
        </LinearLayout>

        <!-- Card 2: Current Monthly Expenses -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_edittext"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/tvExpensesLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Expenses This Month"
                android:textColor="#F3DADA"
                android:textSize="20dp" />

            <TextView
                android:id="@+id/tvExpensesValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="R 0,00"
                android:textColor="@android:color/white"
                android:textSize="24sp"
                android:textStyle="bold"
                android:layout_marginTop="8dp" />
        </LinearLayout>

        <!-- Card 3: Progress toward Savings Goals -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:layout_marginBottom="20dp"
            android:background="@drawable/bg_edittext"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/tvSavingsLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Savings Goal"
                android:textColor="#F3DADA"
                android:textSize="20dp" />

            <TextView
                android:id="@+id/tvSavingsValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="R 0,000 / R 0,000"
                android:textColor="@android:color/white"
                android:textSize="24sp"
                android:textStyle="bold"
                android:layout_marginTop="8dp" />
        </LinearLayout>

        <!-- Section Title for action buttons -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Quick Actions"
            android:textColor="@android:color/white"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="14dp" />


        <!--
            Quick Action Grid
            The buttons are split into rows. Each button uses layout_weight="1"
            to ensure they are exactly the same size in their row.
        -->

        <!-- Row 1: Manage Expenses -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <Button
                android:id="@+id/btnAddExpense"
                android:layout_width="0dp"
                android:layout_height="45dp"
                android:layout_marginRight="8dp"
                android:layout_weight="1"
                android:background="@drawable/bg_button"
                android:text="Add Expense"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:textSize="20dp" />

            <Button
                android:id="@+id/btnViewExpenses"
                android:layout_width="0dp"
                android:layout_height="45dp"
                android:layout_weight="1"
                android:layout_marginLeft="8dp"
                android:background="@drawable/bg_button"
                android:text="View Expenses"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:textSize="20dp" />
        </LinearLayout>

        <!-- Row 2: Goals and Insights -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <Button
                android:id="@+id/btnGoals"
                android:layout_width="0dp"
                android:layout_height="45dp"
                android:layout_weight="1"
                android:layout_marginRight="8dp"
                android:background="@drawable/bg_button"
                android:text="Goals"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:textSize="20dp" />

            <Button
                android:id="@+id/btnAnalysis"
                android:layout_width="0dp"
                android:layout_height="45dp"
                android:layout_weight="1"
                android:layout_marginLeft="8dp"
                android:background="@drawable/bg_button"
                android:text="Analysis"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:textSize="20dp"/>
        </LinearLayout>

        <!-- Row 3: Account Options -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnAchievements"
                android:layout_width="0dp"
                android:layout_height="45dp"
                android:layout_weight="1"
                android:layout_marginRight="8dp"
                android:background="@drawable/bg_button"
                android:text="Achievements"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:textSize="20dp" />

            <Button
                android:id="@+id/btnLogout"
                android:layout_width="0dp"
                android:layout_height="45dp"
                android:layout_weight="1"
                android:layout_marginLeft="8dp"
                android:background="@drawable/bg_button"
                android:text="Logout"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:textSize="20dp" />
        </LinearLayout>

    </LinearLayout>

</LinearLayout>
