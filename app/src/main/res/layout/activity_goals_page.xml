<?xml version="1.0" encoding="utf-8"?>

<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/goalsMain"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@drawable/guardia"
    tools:context=".goals_page">

    <!-- Top bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="35dp"
        android:orientation="horizontal">

        <!-- Bell icon on the left -->
        <ImageButton
            android:id="@+id/btnGoalsMenu"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@android:color/transparent"
            android:contentDescription="notification button"
            android:padding="8dp"
            android:src="@drawable/phiwe_bell"
            app:tint="@android:color/white" />

        <!-- Spacer -->
        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <!-- Moon icon on the right -->
        <ImageButton
            android:id="@+id/btnGoalsSettings"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@android:color/transparent"
            android:contentDescription="themes button"
            android:padding="8dp"
            android:src="@drawable/moon"
            app:tint="@android:color/white" />
    </LinearLayout>

    <!-- Main content section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingLeft="24dp"
        android:paddingRight="24dp"
        android:paddingTop="20dp">

        <!-- Page icon -->
        <ImageView
            android:id="@+id/imgGoalsIcon"
            android:layout_width="110dp"
            android:layout_height="110dp"
            android:layout_marginBottom="20dp"
            android:background="@drawable/bg_circle"
            android:padding="22dp"
            android:src="@drawable/phiwe_person"
            app:tint="#2E2E2E" />

        <!-- Page title -->
        <TextView
            android:id="@+id/tvGoalsTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            android:text="Savings Goals"
            android:textColor="@android:color/white"
            android:textSize="24sp"
            android:textStyle="bold" />

        <!-- Goal name -->
        <EditText
            android:id="@+id/etGoalName"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_edittext"
            android:hint="Enter Goal Name"
            android:inputType="textCapWords"
            android:paddingLeft="16dp"
            android:paddingRight="16dp"
            android:textColor="@android:color/white"
            android:textColorHint="#D9B2B2" />

        <!-- Target amount -->
        <EditText
            android:id="@+id/etTargetAmount"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_edittext"
            android:hint="Enter Target Amount"
            android:inputType="numberDecimal"
            android:paddingLeft="16dp"
            android:paddingRight="16dp"
            android:textColor="@android:color/white"
            android:textColorHint="#D9B2B2" />

        <!-- Current saved amount -->
        <EditText
            android:id="@+id/etCurrentSaved"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginBottom="20dp"
            android:background="@drawable/bg_edittext"
            android:hint="Enter Current Saved Amount"
            android:inputType="numberDecimal"
            android:paddingLeft="16dp"
            android:paddingRight="16dp"
            android:textColor="@android:color/white"
            android:textColorHint="#D9B2B2" />

        <!-- Calculate progress button -->
        <Button
            android:id="@+id/btnCalculateGoal"
            android:layout_width="170dp"
            android:layout_height="60dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_button"
            android:text="Calculate Progress"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            android:textSize="14sp" />

        <!-- Back button -->
        <Button
            android:id="@+id/btnBackFromGoals"
            android:layout_width="170dp"
            android:layout_height="60dp"
            android:layout_marginBottom="20dp"
            android:background="@drawable/bg_button"
            android:text="Back to Dashboard"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            android:textSize="14sp" />

        <!-- Results card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_edittext"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/tvGoalResultTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Goal Progress"
                android:textColor="@android:color/white"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvGoalNameResult"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Goal: Not calculated yet"
                android:textColor="#F3DADA"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvTargetResult"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Target Amount: R 0.00"
                android:textColor="#F3DADA"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvSavedResult"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Current Saved: R 0.00"
                android:textColor="#F3DADA"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvPercentageResult"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Progress: 0%"
                android:textColor="@android:color/white"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>

    </LinearLayout>

</LinearLayout>