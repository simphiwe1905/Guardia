<?xml version="1.0" encoding="utf-8"?>

<?xml version="1.0" encoding="utf-8"?>

<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".login_page">

    <!-- Background Image -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/guardia"
        android:scaleType="centerCrop" />

    <!-- Optional Dark Overlay (for better visibility) -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#80000000"/>


<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/goalsMain"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:fitsSystemWindows="true">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingTop="24dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="16dp">

            <!-- Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Monthly Spending Goals"
                android:textColor="@android:color/white"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginBottom="16dp" />

            <!-- Month/Year -->
            <EditText
                android:id="@+id/etGoalMonth"
                android:layout_width="match_parent"
                android:layout_height="45dp"
                android:layout_marginBottom="10dp"
                android:background="@drawable/bg_edittext"
                android:hint="Month/Year (MM/YYYY)"
                android:inputType="text"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:textColor="@android:color/white"
                android:textColorHint="#D9B2B2"
                android:textSize="13sp" />

            <!-- Minimum Amount -->
            <EditText
                android:id="@+id/etMinAmount"
                android:layout_width="match_parent"
                android:layout_height="45dp"
                android:layout_marginBottom="10dp"
                android:background="@drawable/bg_edittext"
                android:hint="Minimum Spending Goal (R)"
                android:inputType="numberDecimal"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:textColor="@android:color/white"
                android:textColorHint="#D9B2B2"
                android:textSize="13sp" />

            <!-- Maximum Amount -->
            <EditText
                android:id="@+id/etMaxAmount"
                android:layout_width="match_parent"
                android:layout_height="45dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/bg_edittext"
                android:hint="Maximum Spending Limit (R)"
                android:inputType="numberDecimal"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:textColor="@android:color/white"
                android:textColorHint="#D9B2B2"
                android:textSize="13sp" />

            <!-- Save Button -->
            <Button
                android:id="@+id/btnSaveGoal"
                android:layout_width="160dp"
                android:layout_height="40dp"
                android:layout_marginBottom="8dp"
                android:background="@drawable/bg_button"
                android:text="Save Goal"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:textSize="13sp" />

            <!-- Back Button -->
            <Button
                android:id="@+id/btnBackToDashboard"
                android:layout_width="160dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_button"
                android:text="Back to Dashboard"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:textSize="13sp" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>
</FrameLayout>