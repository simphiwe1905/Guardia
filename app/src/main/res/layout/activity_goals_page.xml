<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Background Image -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/guardia"
        android:scaleType="centerCrop" />

    <!-- Dark overlay -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#80000000"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingTop="24dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="16dp">

            <!-- Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Set Your Goals"
                android:textColor="@android:color/white"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginBottom="20dp" />

            <!-- Savings Goal Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Savings Goal"
                android:textColor="#F3DADA"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <!-- Goal Name -->
            <EditText
                android:id="@+id/etGoalName"
                android:layout_width="match_parent"
                android:layout_height="45dp"
                android:layout_marginBottom="10dp"
                android:background="@drawable/bg_edittext"
                android:hint="Goal Name (e.g., New Car)"
                android:inputType="textCapWords"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:textColor="@android:color/white"
                android:textColorHint="#D9B2B2"
                android:textSize="13sp" />

            <!-- Target Amount -->
            <EditText
                android:id="@+id/etTargetAmount"
                android:layout_width="match_parent"
                android:layout_height="45dp"
                android:layout_marginBottom="20dp"
                android:background="@drawable/bg_edittext"
                android:hint="Target Amount (R)"
                android:inputType="numberDecimal"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:textColor="@android:color/white"
                android:textColorHint="#D9B2B2"
                android:textSize="13sp" />

            <!-- Monthly Spending Goal Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Monthly Spending Goal"
                android:textColor="#F3DADA"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <!-- Month/Year -->
            <EditText
                android:id="@+id/etGoalMonth"
                android:layout_width="match_parent"
                android:layout_height="45dp"
                android:layout_marginBottom="10dp"
                android:background="@drawable/bg_edittext"
                android:hint="Month/Year (MM/YYYY)"
                android:inputType="text"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:textColor="@android:color/white"
                android:textColorHint="#D9B2B2"
                android:textSize="13sp" />

            <!-- Minimum Amount -->
            <EditText
                android:id="@+id/etMinAmount"
                android:layout_width="match_parent"
                android:layout_height="45dp"
                android:layout_marginBottom="10dp"
                android:background="@drawable/bg_edittext"
                android:hint="Minimum Spending (R)"
                android:inputType="numberDecimal"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:textColor="@android:color/white"
                android:textColorHint="#D9B2B2"
                android:textSize="13sp" />

            <!-- Maximum Amount -->
            <EditText
                android:id="@+id/etMaxAmount"
                android:layout_width="match_parent"
                android:layout_height="45dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/bg_edittext"
                android:hint="Maximum Spending (R)"
                android:inputType="numberDecimal"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:textColor="@android:color/white"
                android:textColorHint="#D9B2B2"
                android:textSize="13sp" />

            <!-- Save Button -->
            <Button
                android:id="@+id/btnSaveGoal"
                android:layout_width="175dp"
                android:layout_height="40dp"
                android:layout_marginBottom="8dp"
                android:background="@drawable/bg_button"
                android:text="Save Goals"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:textSize="13sp" />

            <!-- Back Button -->
            <Button
                android:id="@+id/btnBackToDashboard"
                android:layout_width="175dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_button"
                android:text="Back to Dashboard"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:textSize="13sp" />

        </LinearLayout>
    </ScrollView>
</FrameLayout>