<?xml version="1.0" encoding="utf-8"?>

<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:background="@drawable/guardia"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Top bar section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="35dp"
        android:orientation="horizontal">

        <!-- Left icon -->
        <ImageButton
            android:id="@+id/btnDashboardMenu"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@android:color/transparent"
            android:contentDescription="Menu button"
            android:padding="8dp"
            android:src="@drawable/phiwe_bell"
            app:tint="@android:color/white" />

        <!-- Spacer to push the next icon to the right -->
        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <!-- Right icon -->
        <ImageButton
            android:id="@+id/btnDashboardSettings"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@android:color/transparent"
            android:contentDescription="settings button"
            android:padding="8dp"
            android:src="@drawable/moon"
            app:tint="@android:color/white" />
    </LinearLayout>

    <!-- Profile / welcome section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="24dp">



        <!-- User icon -->
        <ImageView
            android:id="@+id/imgDashboardProfile"
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:background="@drawable/bg_circle"
            android:padding="14dp"
            android:src="@drawable/phiwe_person"
            app:tint="#2E2E2E" />

        <!-- Space between image and text -->
        <View
            android:layout_width="16dp"
            android:layout_height="1dp" />

        <!-- Welcome text section -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvWelcome"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="This is your expense summary:"
                android:textColor="@android:color/white"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvUsernameDisplay"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="User's Name"
                android:textColor="#D9B2B2"
                android:textSize="16sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Expense name -->
    <TextView
        android:id="@+id/tvExpenseName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Expense"
        android:textColor="@android:color/white"
        android:textSize="18sp"
        android:textStyle="bold" />

    <!-- Expense amount -->
    <TextView
        android:id="@+id/tvExpenseAmount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="Amount: R 000"
        android:textColor="#F3DADA"
        android:textSize="14sp" />

    <!-- Expense category -->
    <TextView
        android:id="@+id/tvExpenseCategory"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Category: "
        android:textColor="#F3DADA"
        android:textSize="14sp" />

    <!-- Expense date -->
    <TextView
        android:id="@+id/tvExpenseDate"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Date: 00/00/0000"
        android:textColor="#F3DADA"
        android:textSize="14sp" />

    <!-- Expense description -->
    <TextView
        android:id="@+id/tvExpenseDescription"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Description: "
        android:textColor="#F3DADA"
        android:textSize="14sp" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:padding="16dp">

        <!-- Back button -->
        <Button
            android:id="@+id/btnReturnToDashboard"
            android:layout_width="160dp"
            android:layout_height="45dp"
            android:background="@color/black"
            android:text="Back to Dashboard"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            android:textSize="14sp" />

        <Button
            android:id="@+id/btnLogout"
            android:layout_width="0dp"
            android:layout_height="45dp"
            android:layout_weight="1"
            android:layout_marginLeft="8dp"
            android:background="@drawable/bg_button"
            android:text="Logout"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            android:textSize="13sp" />

    </LinearLayout>
</LinearLayout>

